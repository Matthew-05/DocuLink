<?xml version="1.0" encoding="UTF-8"?>
<!--
  DocuLink WiX v3 installer.

  This file contains the product definition, directory layout, VSTO registry
  entries, prerequisite checks, and UI.  File components are in a separate
  doculink-files.wxs that is generated at build time by heat.exe — do not
  commit that file to source control.

  Build:  installer\build-installer.ps1
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="{1F4C363C-18FE-4A4D-AA46-AF8DFB16F090}"
           Name="DocuLink"
           Language="1033"
           Manufacturer="Matthew Tryon"
           Version="$(var.ProductVersion)"
           UpgradeCode="{0B175035-7BD2-428F-AC4D-4FA1CF677172}">

    <!-- Per-user install; no elevation required. -->
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perUser" />

    <!-- Prevent downgrade; allow same-version reinstall. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of DocuLink is already installed." />

    <!-- Embed all files in the MSI as a single cabinet. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ── Icon ──────────────────────────────────────────────────────────────── -->
    <Icon Id="InstallIcon" SourceFile="$(sys.SOURCEFILEDIR)..\src\resources\branding\doculink-icon.ico" />

    <!-- ── UI ─────────────────────────────────────────────────────────────── -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)License.rtf" />

    <!-- ── Prerequisites ─────────────────────────────────────────────────── -->
    <!--
      VSTO Runtime 4.0 is required to host .NET Framework VSTO add-ins.
      VS-bundled installs write "v4"  under WOW6432Node (Win64="no").
      Standalone vstor40.exe writes  "v4R" under either hive.
      Check all four combinations so both install paths are covered.
    -->
    <Property Id="VSTO_V4_X86">
      <RegistrySearch Id="VstoV4X86" Root="HKLM"
        Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4"
        Name="Install" Type="raw" Win64="no" />
    </Property>
    <Property Id="VSTO_V4_X64">
      <RegistrySearch Id="VstoV4X64" Root="HKLM"
        Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4"
        Name="Install" Type="raw" Win64="yes" />
    </Property>
    <Property Id="VSTO_V4R_X86">
      <RegistrySearch Id="VstoV4RX86" Root="HKLM"
        Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4R"
        Name="Install" Type="raw" Win64="no" />
    </Property>
    <Property Id="VSTO_V4R_X64">
      <RegistrySearch Id="VstoV4RX64" Root="HKLM"
        Key="SOFTWARE\Microsoft\VSTO Runtime Setup\v4R"
        Name="Install" Type="raw" Win64="yes" />
    </Property>
    <Condition Message="Microsoft Visual Studio Tools for Office Runtime 4.0 is required.&#10;Download it from https://aka.ms/vstor40 and run this installer again.">
      <![CDATA[Installed OR VSTO_V4_X86 OR VSTO_V4_X64 OR VSTO_V4R_X86 OR VSTO_V4R_X64]]>
    </Condition>

    <!-- ── Directory layout ───────────────────────────────────────────────── -->
    <!--
      Installs to %LOCALAPPDATA%\Programs\DocuLink\.
      LocalAppDataFolder is a WiX built-in that resolves %LOCALAPPDATA%.
    -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="UserProgramsFolder" Name="Programs">
          <Directory Id="INSTALLDIR" Name="DocuLink" />
        </Directory>
      </Directory>
    </Directory>

    <!-- ── Features ──────────────────────────────────────────────────────── -->
    <Feature Id="Complete" Title="DocuLink" Level="1">
      <!-- All add-in files, web UI, and Python worker (generated by heat.exe) -->
      <ComponentGroupRef Id="ReleaseFiles" />
      <!-- VSTO Excel registration keys -->
      <ComponentGroupRef Id="VstoRegistry" />
    </Feature>

    <!-- ── VSTO registration ──────────────────────────────────────────────── -->
    <!--
      Registers the add-in with Excel under HKCU so no elevation is needed.
      The |vstolocal suffix tells the VSTO runtime to load from the local file
      system rather than from a ClickOnce deployment URL.
    -->
    <ComponentGroup Id="VstoRegistry" Directory="INSTALLDIR">
      <Component Id="VstoRegistration" Guid="{A2B3C4D5-E6F7-8901-BCDE-F23456789012}">
        <RegistryValue Root="HKCU"
          Key="Software\Microsoft\Office\Excel\Addins\DocuLink.Addin"
          Name="Description"
          Value="DocuLink - Embed and view PDFs in Excel"
          Type="string" KeyPath="yes" />
        <RegistryValue Root="HKCU"
          Key="Software\Microsoft\Office\Excel\Addins\DocuLink.Addin"
          Name="FriendlyName"
          Value="DocuLink"
          Type="string" />
        <RegistryValue Root="HKCU"
          Key="Software\Microsoft\Office\Excel\Addins\DocuLink.Addin"
          Name="LoadBehavior"
          Value="3"
          Type="integer" />
        <RegistryValue Root="HKCU"
          Key="Software\Microsoft\Office\Excel\Addins\DocuLink.Addin"
          Name="Manifest"
          Value="[INSTALLDIR]DocuLink.Addin.vsto|vstolocal"
          Type="string" />
      </Component>
    </ComponentGroup>

  </Product>
</Wix>
