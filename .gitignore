# --- OS ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Visual Studio / MSBuild (.NET Framework VSTO) ---
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.log
*.svclog
*.cachefile
*.user
*.userosscache
*.rsuser
*.suo
*.sln.docstates
*.userprefs
*.vsp
*.vspx
*.orig

# Visual Studio working dir (often under project tree)
.vs/
**/.vs/

# NuGet (packages.config / legacy)
[Pp]ackages/*
![Pp]ackages/build/
*.nupkg
project.lock.json
project.fragment.lock.json
artifacts/

# ClickOnce / publish output (if used later)
app.publish/
**/publish/

# Strong-name / signing keys (never commit real keys)
*.pfx
*.snk
!**/placeholder.snk

# Coverage / test
TestResults/
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml

# --- VS Code / JetBrains ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sln.iml

# --- Web (Node / Vite / pnpm-npm-yarn) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Bundler output (regenerated on build)
/dist/
/dist-ssr/
src/web/**/dist/
src/web/**/dist-ssr/
*.local

# Vite / tooling caches
.vite/
.turbo/
.eslintcache
*.tsbuildinfo

# --- Python (OCR worker / embedded runtime build) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller worker build output (~150 MB — run src/python/build-worker.ps1 to generate)
src/python/dist/
src/python/build/

# Tesseract OCR binaries (~30 MB — run src/python/download-tesseract.ps1 to fetch)
src/python/tesseract/

# Ghostscript binaries (~150 MB — run src/python/download-ghostscript.ps1 to fetch)
src/python/ghostscript/

# Virtual environments
.venv/
venv/
ENV/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# pyenv
.python-version

# --- Local / secrets (never commit) ---
.env
.env.*
!.env.example
secrets.json
*.local.json

# --- Misc ---
*.tmp
*.temp
~$*
