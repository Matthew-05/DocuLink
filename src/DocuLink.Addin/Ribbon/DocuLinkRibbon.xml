<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="DocuLink.Tab" label="DocuLink">
        <group id="DocuLink.Group.General" label="General">
          <menu id="DocuLink.MenuViewer"
                label="Viewer"
                size="large"
                getImage="GetViewerMenuImage">
            <button id="DocuLink.BtnTaskPane"
                    label="Open in Task Pane"
                    onAction="OnShowTaskPane" />
            <button id="DocuLink.BtnViewerWindow"
                    label="Open in Separate Window"
                    onAction="OnShowViewerWindow" />
            <toggleButton id="DocuLink.ToggleAutoOpenViewer"
                          label="Automatically Open Viewer"
                          getPressed="GetAutoOpenViewerOnCellClick"
                          onAction="OnToggleAutoOpenViewerOnCellClick" />
          </menu>
          <button id="DocuLink.BtnAddPdf"
                  label="Add PDF"
                  size="large"
                  getImage="GetAddPdfImage"
                  onAction="OnAddPdfDocuments" />
          <button id="DocuLink.BtnDeleteLinks"
                  label="Delete Links"
                  size="large"
                  getImage="GetDeleteLinksImage"
                  onAction="OnDeleteLinksInSelection" />
          <button id="DocuLink.BtnManageFiles"
                  label="Manage Files"
                  size="large"
                  getImage="GetManageFilesImage"
                  onAction="OnManageFiles" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
